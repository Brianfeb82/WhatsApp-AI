# App
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001

# Database (Supabase or local Postgres)
DATABASE_URL="postgresql://postgres:password@localhost:5432/whatsapp_ai"

# AI — get free key at console.groq.com
GROQ_API_KEY=your_groq_key_here

# Local Ollama (optional, for offline dev)
OLLAMA_URL=http://localhost:11434

# Auth (Clerk — free at clerk.com)
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# WhatsApp — no key needed for Baileys, just run the app and scan QR

# Logging
LOG_LEVEL=debug
